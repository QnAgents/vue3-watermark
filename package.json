{
  "name": "vue3-watermark",
  "version": "1.0.0",
  "description": "Vue 3 watermark directive — SVG-based, supports tiled ID-card array and centered hint text",
  "keywords": ["vue3", "watermark", "directive", "svg", "水印"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vue": "^3.4.0"
  }
}
